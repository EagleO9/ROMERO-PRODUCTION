  for(var i=1;i<d.length;i++){
    var dk=dateKey(d[i][1]); if(!dk||dk.slice(0,7)!==ym) continue;
    var m=String(d[i][2]||'').trim()||'-'; var o=String(d[i][3]||'').trim()||'-';
    var kg=Number(d[i][5])||0; var mt=Number(d[i][6])||0;
    if(!byM[m])byM[m]={kg:0,meter:0,days:{}}; byM[m].kg+=kg; byM[m].meter+=mt; byM[m].days[dk]=1;
    if(!byO[o])byO[o]={kg:0,meter:0,days:{}}; byO[o].kg+=kg; byO[o].meter+=mt; byO[o].days[dk]=1;
  }
  function pack(obj){ return Object.keys(obj).map(function(k){ return {name:k,kg:round(obj[k].kg),meter:round(obj[k].meter),days:Object.keys(obj[k].days).length}; }).sort(function(a,b){return b.kg-a.kg;}); }
  return {ok:true, ym:ym, machines:pack(byM), operators:pack(byO)};
}

