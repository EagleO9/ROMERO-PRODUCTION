function _alertSec_(title, lines){ if(!lines||!lines.length) return ''; return '\n■ '+title+'\n'+lines.map(function(l){return '  • '+l;}).join('\n')+'\n'; }
function _daysAgo_(d){ try{ return Math.floor((new Date()-new Date(d))/(24*3600*1000)); }catch(e){ return 0; } }

function _alertStoreCritical_(){
  try{ var items=_rmItemsMap_(); var td=sheetData_(RM_TXN_SHEET); var io={};
    for(var i=1;i<td.length;i++){ var sku=String(td[i][1]||'').trim(); if(!sku)continue; io[sku]=(io[sku]||0)+((String(td[i][3])==='OUT')?-(Number(td[i][4])||0):(Number(td[i][4])||0)); }
    var out=[]; Object.keys(items).forEach(function(sku){ var it=items[sku]; if(String(it.active).toLowerCase()==='no')return; if(!(it.reorder>0))return;
      var stock=round(it.opening+(io[sku]||0)); if(stock<=it.reorder*0.33) out.push(it.item+' — '+stock+' / '+it.reorder); });
    return out.slice(0,25);
  }catch(e){ return []; }
}
function _alertLateOrders_(days){
  try{ ensureOrders_(); var d=sheetData_(SHEETS.ORDERS); var m=ordCol_(); var out=[];
    for(var i=1;i<d.length;i++){ var st=String(d[i][m['status']]||'').trim(); if(st==='Completed'||st==='Done'||st==='Cancelled')continue;
      var age=_daysAgo_(d[i][m['date']]); if(age>=days){ var s=orderSummary_(d[i],m); if(s.totalPending>0) out.push(String(d[i][m['customer']]||'')+' · '+String(d[i][m['order id']]||'')+' — '+age+' din, pending '+s.totalPending); } }
    return out;
  }catch(e){ return []; }
}
function _alertStuckLots_(days){
  try{ setupLots(); var prog=lotMovesSum_(); var sh=getSS().getSheetByName(LOTS_SHEET); var c=lotCols_(sh); var d=sh.getDataRange().getValues(); var out=[];
