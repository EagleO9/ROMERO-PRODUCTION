/* ======================= CLEAR OPENINGS — run once from editor (Run ▶) =======================
   Deletes ALL opening entries (LEDGER 'Opening' rows + BORE STOCK 'Opening' rows + CONTRACTOR LEDGER 'Opening' rows)
   and unlocks opening so fresh opening can be entered. Data of normal entries is NOT touched. */
function CLEAR_OPENINGS(){
  const ss=getSS(); const report=[];
  // LEDGER: Notes column (index 12) === 'Opening'
  var led=ss.getSheetByName(SHEETS.LEDGER);
  if(led){ var d=led.getDataRange().getValues(); var n=0;
    for(var i=d.length-1;i>=1;i--){ if(String(d[i][12]||'').trim()==='Opening'){ led.deleteRow(i+1); n++; } }
    report.push('LEDGER: '+n+' opening rows deleted'); }
  // BORE STOCK: Reference column (index 6) === 'Opening'
  var bs=ss.getSheetByName(BORE_STOCK_SHEET);
  if(bs){ var b=bs.getDataRange().getValues(); var m=0;
    for(var j=b.length-1;j>=1;j--){ if(String(b[j][6]||'').trim()==='Opening'){ bs.deleteRow(j+1); m++; } }
    report.push('BORE STOCK: '+m+' opening rows deleted'); }
  // CONTRACTOR LEDGER: Source column (index 6) === 'Opening'
  var cl=ss.getSheetByName(SHEETS.CLEDGER);
  if(cl){ var c=cl.getDataRange().getValues(); var k=0;
    for(var t=c.length-1;t>=1;t--){ if(String(c[t][6]||'').trim()==='Opening'){ cl.deleteRow(t+1); k++; } }
    report.push('CONTRACTOR LEDGER: '+k+' opening rows deleted'); }
  PropertiesService.getScriptProperties().setProperty('OPENING_LOCKED','no');
  report.push('Opening UNLOCKED — fresh opening daal sakte ho.');
  Logger.log(report.join('\n'));
  return report;
}

