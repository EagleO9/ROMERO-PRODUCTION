  const sh=getSS().getSheetByName(ITEMS_MASTER_SHEET); const d=sh.getDataRange().getValues(); const out=[];
  const head=d[0].map(function(x){return String(x||'').trim().toLowerCase();});
  function c(label){ return head.indexOf(String(label).toLowerCase()); }
  const cName=c('Item Name'), cType=c('Type'), cKg=c('Roll KG'), cAct=c('Active'), cDesc=c('Description'), cDType=c('Dispatch Type'), cQual=c('Quality');
  for(let i=1;i<d.length;i++){ const n=String(d[i][cName]||'').trim(); if(!n) continue;
    out.push({name:n, type:(String(d[i][cType]||'Both').trim()||'Both'), kg:Number(d[i][cKg])||0, active:String(d[i][cAct]||'Yes').trim().toLowerCase()!=='no', desc:(cDesc>=0?String(d[i][cDesc]||'').trim():''), dispatchType:(cDType>=0?String(d[i][cDType]||'').trim():''), quality:(cQual>=0?String(d[i][cQual]||'').trim():''), row:i+1}); }
  _SETUP.imCache=out; return out;
}
function itemsRoll_(){ const r=_itemsMasterRows_().filter(function(x){return x.active&&(x.type==='Roll'||x.type==='Both');}).map(function(x){return x.name;}); return r.length?r:ITEMS.slice(); }
function itemsBora_(){ const r=_itemsMasterRows_().filter(function(x){return x.active&&(x.type==='Bora'||x.type==='Both');}).map(function(x){return x.name;}); return r.length?r:ITEMS.slice(); }
function rollKgMap_(){
  const m={}; _itemsMasterRows_().forEach(function(x){ if(x.type==='Roll'||x.type==='Both'){ m[x.name]=x.kg||ROLL_KG[x.name]||0; } });
  Object.keys(ROLL_KG).forEach(function(k){ if(m[k]===undefined) m[k]=ROLL_KG[k]; });
  return m;
}
function getItemsMaster(user){
  if(!isAllAdmin_(user)) throw new Error('Only admin.');
  const rows=_itemsMasterRows_();
  return {ok:true,
    roll:rows.filter(function(x){return x.type==='Roll'||x.type==='Both';}).map(function(x){return {name:x.name,kg:x.kg,active:x.active,both:x.type==='Both'};}),
    bora:rows.filter(function(x){return x.type==='Bora'||x.type==='Both';}).map(function(x){return {name:x.name,desc:x.desc,dispatchType:x.dispatchType,quality:x.quality,active:x.active,both:x.type==='Both'};}) };
}
function addItemMaster(user,e){
  if(!isAllAdmin_(user)) throw new Error('Only admin.');
  setupItemsMaster_(); e=e||{};
  const base=String(e.name||'').trim(); const type=(String(e.type||'').trim()||'Roll'); const kg=round(e.kg);
  const desc=String(e.description||e.desc||'').trim(); const dispatchType=String(e.dispatchType||'').trim(); const quality=String(e.quality||'').trim();
  if(!base) return {ok:false,msg:'Item ka naam daalo'};
  if(['Roll','Bora','Both'].indexOf(type)<0) return {ok:false,msg:'Type galat'};
  if(type!=='Bora' && !(kg>0)) return {ok:false,msg:'Roll item ke liye per-roll KG daalo'};
  if(type==='Bora' && (!desc||!dispatchType||!quality)) return {ok:false,msg:'Bora item ke liye description, type aur quality required hai'};
  const name=(type==='Bora')?(base+' '+desc+' · '+dispatchType+' · '+quality).replace(/\s+/g,' ').trim():base;
  const rows=_itemsMasterRows_();
  for(let i=0;i<rows.length;i++){ if(rows[i].name.toLowerCase()===name.toLowerCase()) return {ok:false,msg:'"'+rows[i].name+'" pehle se hai'}; }
  const sh=getSS().getSheetByName(ITEMS_MASTER_SHEET); const head=sh.getRange(1,1,1,sh.getLastColumn()).getValues()[0].map(function(x){return String(x||'').trim().toLowerCase();});
  function c(label){ return head.indexOf(String(label).toLowerCase()); }
  const arr=new Array(sh.getLastColumn()).fill('');
  arr[c('Item Name')]=name; arr[c('Type')]=type; arr[c('Roll KG')]=(type==='Bora'?'':kg); arr[c('Active')]='Yes';
  if(c('Description')>=0) arr[c('Description')]=desc;
  if(c('Dispatch Type')>=0) arr[c('Dispatch Type')]=dispatchType;
  if(c('Quality')>=0) arr[c('Quality')]=quality;
  sh.appendRow(arr);
  _SETUP.imCache=null;
  if(type==='Bora'){ _SETUP.boraFG=false; try{ensureBoraFGItems_();}catch(_e){} }
  logAudit_(requireUser_(user),'Item Added',name+' · '+type+(kg?(' · '+kg+'kg'):''));
  return {ok:true};
}
function setItemActive(user,name,active){
  if(!isAllAdmin_(user)) throw new Error('Only admin.');
  setupItemsMaster_(); const sh=getSS().getSheetByName(ITEMS_MASTER_SHEET); const head=sh.getRange(1,1,1,sh.getLastColumn()).getValues()[0].map(function(x){return String(x||'').trim().toLowerCase();}); const activeCol=head.indexOf('active')+1;
  const rows=_itemsMasterRows_();
  for(let i=0;i<rows.length;i++){ if(rows[i].name===String(name)){ sh.getRange(rows[i].row,activeCol).setValue(active?'Yes':'No'); _SETUP.imCache=null; logAudit_(requireUser_(user),'Item '+(active?'On':'Off'),name); return {ok:true}; } }
  return {ok:false,msg:'Item nahi mila'};
}

/* ======================= KNITTING ↔ SLITTING STOCK (actual kg + meter, no rolls) ======================= */
const SLITLOG_SHEET='SLIT LOG';
function setupSlitLog_(){
  if(_SETUP.slitlog) return; _SETUP.slitlog=true;
  const ss=getSS();
  if(!ss.getSheetByName(SLITLOG_SHEET)){
    const s=ss.insertSheet(SLITLOG_SHEET);
    const h=['Timestamp','Date','Quality','Kg Slit','Meter Slit','Rolls Slit','Rolls Forwarded','By'];
    s.getRange(1,1,1,h.length).setValues([h]).setFontWeight('bold').setBackground('#0f2942').setFontColor('#ffffff'); s.setFrozenRows(1);
  }
}
function getKnitSlitStock(user){
  requireDept_(user,RASCHEL_DEPT); ensureRaschel_(); setupSlitLog_();
  const kd=getSS().getSheetByName(KNITTING_SHEET).getDataRange().getValues();
  const m={};
  for(let i=1;i<kd.length;i++){ const q=String(kd[i][4]||'').trim(); if(!q) continue;
    if(!m[q])m[q]={kKg:0,kM:0,sKg:0,sM:0};
    m[q].kKg+=Number(kd[i][5])||0; m[q].kM+=Number(kd[i][6])||0; }
  const sd=getSS().getSheetByName(SLITLOG_SHEET).getDataRange().getValues();
  const RKG=rollKgMap_();
  for(let j=1;j<sd.length;j++){ const q=String(sd[j][2]||'').trim(); if(!q) continue;
    if(!m[q])m[q]={kKg:0,kM:0,sKg:0,sM:0};
    const loggedKg=Number(sd[j][3])||0;
    m[q].sKg+=loggedKg>0?loggedKg:((Number(sd[j][6])||0)*(RKG[q]||0));
    m[q].sM+=Number(sd[j][4])||0; }
  const rows=Object.keys(m).map(function(q){ const x=m[q];
    return {item:q, knitKg:round(x.kKg), knitM:round(x.kM), slitKg:round(x.sKg), slitM:round(x.sM), balKg:round(x.kKg-x.sKg), balM:round(x.kM-x.sM)}; });
  rows.sort(function(a,b){return b.balKg-a.balKg;});
  return {ok:true, rows:rows};
}

