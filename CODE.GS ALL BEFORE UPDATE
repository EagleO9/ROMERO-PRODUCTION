/* ======================= READY STOCK PDF (printable, with date duration) ======================= */
function fgStockPdf(user, loc, from, to){
  var u=requireUser_(user); if(!isAllAdmin_(user)&&!u.can.dispatch&&!u.can.order_entry&&!u.can.packing) throw new Error('No access');
  loc=(String(loc||'Factory').trim()==='Godown')?'Godown':'Factory';
  var st=getFGStock(user,loc); var items=(st.items||[]).filter(function(x){return x.qty!==0;});
  var byQ={FIRST:[],SECOND:[]}; items.forEach(function(x){ (byQ[x.quality]||(byQ[x.quality]=[])).push(x); });
  function rows(arr){ return arr.map(function(x){ return '<tr><td style="border:1px solid #999;padding:4px 6px;">'+x.sku+'</td><td style="border:1px solid #999;padding:4px 6px;">'+x.name+'</td><td style="border:1px solid #999;padding:4px 6px;">'+x.quality+'</td><td style="border:1px solid #999;padding:4px 6px;text-align:right;">'+x.qty+'</td><td style="border:1px solid #999;padding:4px 6px;">'+x.uom+'</td><td style="border:1px solid #999;padding:4px 6px;text-align:right;">'+x.pack+'</td><td style="border:1px solid #999;padding:4px 6px;text-align:right;">'+x.pcs+'</td></tr>'; }).join(''); }
  var head='<tr style="background:#1c2b21;color:#fff;"><th style="border:1px solid #999;padding:4px 6px;">SKU</th><th style="border:1px solid #999;padding:4px 6px;text-align:left;">Item</th><th style="border:1px solid #999;padding:4px 6px;">Quality</th><th style="border:1px solid #999;padding:4px 6px;">Qty</th><th style="border:1px solid #999;padding:4px 6px;">UOM</th><th style="border:1px solid #999;padding:4px 6px;">Pack</th><th style="border:1px solid #999;padding:4px 6px;">Pcs</th></tr>';
  var html='<div style="font-family:Arial;padding:22px;color:#111;">'
    +'<div style="text-align:center;border-bottom:3px solid #1c2b21;padding-bottom:8px;"><div style="font-size:20px;font-weight:bold;letter-spacing:1px;">ROMERO FINISH GOODS STOCK</div><div style="font-size:13px;color:#555;">'+loc.toUpperCase()+' \u00b7 '+Utilities.formatDate(new Date(),Session.getScriptTimeZone(),'dd-MMM-yyyy HH:mm')+'</div></div>'
    +'<div style="margin:10px 0;font-size:13px;">Total: <b>'+st.totPacks+'</b> packs \u00b7 <b>'+st.totPcs+'</b> pcs</div>'
    +'<table style="width:100%;font-size:11.5px;border-collapse:collapse;">'+head+rows(byQ.FIRST||[])+rows(byQ.SECOND||[])+'</table>';
  from=String(from||'').trim(); to=String(to||'').trim();
  if(from&&to){
    var mv=sheetData_(FG_MOVES_SHEET); var mr='';
    for(var i=1;i<mv.length;i++){ if(String(mv[i][4]||'').trim()!==loc)continue; var dk=dateKey(mv[i][1]); if(!dk||dk<from||dk>to)continue;
      var dir=String(mv[i][5]); var col=dir==='OUT'?'#b91c1c':'#166534';
      mr+='<tr><td style="border:1px solid #999;padding:3px 6px;">'+dk+'</td><td style="border:1px solid #999;padding:3px 6px;">'+String(mv[i][3]||'')+'</td><td style="border:1px solid #999;padding:3px 6px;color:'+col+';font-weight:bold;">'+dir+'</td><td style="border:1px solid #999;padding:3px 6px;text-align:right;">'+round(mv[i][6])+'</td><td style="border:1px solid #999;padding:3px 6px;">'+String(mv[i][8]||'')+'</td><td style="border:1px solid #999;padding:3px 6px;">'+String(mv[i][9]||'')+'</td></tr>'; }
    html+='<div style="margin:16px 0 6px;font-size:13px;font-weight:bold;">Movements '+from+' \u2192 '+to+'</div>'
      +'<table style="width:100%;font-size:11px;border-collapse:collapse;"><tr style="background:#eee;"><th style="border:1px solid #999;padding:3px 6px;">Date</th><th style="border:1px solid #999;padding:3px 6px;text-align:left;">Item</th><th style="border:1px solid #999;padding:3px 6px;">Dir</th><th style="border:1px solid #999;padding:3px 6px;">Qty</th><th style="border:1px solid #999;padding:3px 6px;">Contractor</th><th style="border:1px solid #999;padding:3px 6px;">Party/Ref</th></tr>'+(mr||'<tr><td colspan="6" style="border:1px solid #999;padding:6px;text-align:center;color:#777;">No movement</td></tr>')+'</table>';
  }
  html+='</div>';
  var pdf=Utilities.newBlob(html,'text/html','s.html').getAs('application/pdf'); pdf.setName('ReadyStock_'+loc+'_'+dateKey(new Date())+'.pdf');
  var file=getFolder_('Romero Ready Stock PDFs').createFile(pdf);
  file.setSharing(DriveApp.Access.ANYONE_WITH_LINK,DriveApp.Permission.VIEW);
  logAudit_(u,'FG Stock PDF',loc);
  return {ok:true,url:file.getUrl()};
}

/* ======================= YARN INVENTORY (master + moves ledger; manual IN, warping auto-OUT) =======================
   Screenshot-style yarn inventory. Nothing old removed — new sheets + new functions only.
   YARN ITEMS = master (per-carton conversion). YARN MOVES = ledger (IN manual, OUT from warping boxes opened).
   Stock (Cartons/Cones/Kg) = sum(IN) − sum(OUT) per SKU. */
const YARN_ITEMS_SHEET='YARN ITEMS';
const YARN_MOVES_SHEET='YARN MOVES';
function setupYarn_(){
  if(_SETUP.yarn) return; _SETUP.yarn=true;
  const ss=getSS();
  if(!ss.getSheetByName(YARN_ITEMS_SHEET)){
    const s=ss.insertSheet(YARN_ITEMS_SHEET);
    s.getRange(1,1,1,8).setValues([['SKU','Brand','Category','Quality','Description','Cones/Carton','Kg/Carton','Active']]).setFontWeight('bold').setBackground('#0f2942').setFontColor('#ffffff'); s.setFrozenRows(1);
  }
  if(!ss.getSheetByName(YARN_MOVES_SHEET)){
    const s=ss.insertSheet(YARN_MOVES_SHEET);
    s.getRange(1,1,1,11).setValues([['Timestamp','Date','SKU','Yarn','Direction','Cartons','Cones','Kg','Source','Ref','By']]).setFontWeight('bold').setBackground('#0f2942').setFontColor('#ffffff'); s.setFrozenRows(1);
  }
}
function _yarnItems_(){
  setupYarn_(); if(_SETUP.yarnItems) return _SETUP.yarnItems;
  var d=sheetData_(YARN_ITEMS_SHEET); var m={};
  for(var i=1;i<d.length;i++){ var sku=String(d[i][0]||'').trim(); if(!sku) continue;
    m[sku]={sku:sku,brand:String(d[i][1]||''),category:String(d[i][2]||'YARN'),quality:String(d[i][3]||''),desc:String(d[i][4]||''),conesPerCarton:Number(d[i][5])||0,kgPerCarton:Number(d[i][6])||0,active:String(d[i][7]||'Yes').toLowerCase()!=='no'}; }
  _SETUP.yarnItems=m; return m;
}
function _yarnLabel_(it){ if(!it) return ''; var q=String(it.quality||'').trim(); return String(it.desc||'')+(q?(' · '+q):''); }
function _yarnOptions_(){
  setupYarn_(); var items=_yarnItems_(); var out=[];
  Object.keys(items).forEach(function(sku){ var it=items[sku]; if(!it.active) return; out.push({sku:sku,label:_yarnLabel_(it),desc:it.desc,quality:it.quality,brand:it.brand}); });
  out.sort(function(a,b){ return a.label<b.label?-1:1; }); return out;
}
function _yarnBalances_(){
  setupYarn_(); var mv=sheetData_(YARN_MOVES_SHEET); var bal={};
  for(var i=1;i<mv.length;i++){ var sku=String(mv[i][2]||'').trim(); if(!sku) continue;
    if(!bal[sku]) bal[sku]={cartons:0,cones:0,kg:0};
    var sign=(String(mv[i][4])==='OUT')?-1:1;
    bal[sku].cartons+=sign*(Number(mv[i][5])||0);
    bal[sku].cones+=sign*(Number(mv[i][6])||0);
    bal[sku].kg+=sign*(Number(mv[i][7])||0);
  }
  return bal;
}
function getYarnInventory(user){
  if(!isAllAdmin_(user)) throw new Error('Only admin.');
  setupYarn_(); var items=_yarnItems_(); var bal=_yarnBalances_();
  var list=Object.keys(items).map(function(sku){ var it=items[sku]; var b=bal[sku]||{cartons:0,cones:0,kg:0};
    return {sku:sku,brand:it.brand,category:it.category,quality:it.quality,desc:it.desc,label:_yarnLabel_(it),conesPerCarton:it.conesPerCarton,kgPerCarton:it.kgPerCarton,active:it.active,cartons:round(b.cartons),cones:round(b.cones),kg:round(b.kg)}; });
  list.sort(function(a,b){ return a.sku<b.sku?-1:1; });
  return {ok:true, items:list};
}
function addYarnItem(user,e){
  if(!isAllAdmin_(user)) throw new Error('Only admin.');
  setupYarn_(); e=e||{};
  var brand=String(e.brand||'').trim(); var quality=String(e.quality||'').trim(); var desc=String(e.desc||'').trim();
  var category=String(e.category||'YARN').trim()||'YARN';
  var cpc=Number(e.conesPerCarton)||0; var kpc=Number(e.kgPerCarton)||0;
  if(!desc) return {ok:false,msg:'Yarn description / name daalo'};
  var items=_yarnItems_();
  var sku=String(e.sku||'').trim();
  if(!sku){ var n=Object.keys(items).length+1; sku='YRN_'+pad4(n); while(items[sku]){ n++; sku='YRN_'+pad4(n); } }
  if(items[sku]) return {ok:false,msg:'SKU "'+sku+'" pehle se hai'};
  var dup=null; Object.keys(items).forEach(function(k){ var it=items[k]; if(String(it.desc).toLowerCase()===desc.toLowerCase() && String(it.quality).toLowerCase()===quality.toLowerCase() && String(it.brand).toLowerCase()===brand.toLowerCase()) dup=k; });
  if(dup) return {ok:false,msg:'Ye yarn pehle se hai ('+dup+')'};
  getSS().getSheetByName(YARN_ITEMS_SHEET).appendRow([sku,brand,category,quality,desc,cpc,kpc,'Yes']);
  _SETUP.yarnItems=null; bustMemo_();
  logAudit_(requireUser_(user),'Yarn Item Added',sku+' · '+(brand?brand+' · ':'')+desc+(quality?(' · '+quality):''));
  return {ok:true,sku:sku};
}
function setYarnActive(user,sku,active){
  if(!isAllAdmin_(user)) throw new Error('Only admin.');
  setupYarn_(); var sh=getSS().getSheetByName(YARN_ITEMS_SHEET); var d=sh.getDataRange().getValues();
  for(var i=1;i<d.length;i++){ if(String(d[i][0]||'').trim()===String(sku)){ sh.getRange(i+1,8).setValue(active?'Yes':'No'); _SETUP.yarnItems=null; bustMemo_(); logAudit_(requireUser_(user),'Yarn '+(active?'On':'Off'),String(sku)); return {ok:true}; } }
  return {ok:false,msg:'Yarn nahi mila'};
}
function yarnStockIn(user,e){
  if(!isAllAdmin_(user)) throw new Error('Only admin.');
  setupYarn_(); e=e||{};
  var sku=String(e.sku||'').trim(); if(!sku) return {ok:false,msg:'Yarn select karo'};
  var items=_yarnItems_(); var it=items[sku]; if(!it) return {ok:false,msg:'Yarn nahi mila'};
  var cartons=round(e.cartons), cones=round(e.cones), kg=round(e.kg);
  if(!(cartons>0||cones>0||kg>0)) return {ok:false,msg:'Carton / Cones / Kg me se kuch to daalo'};
  getSS().getSheetByName(YARN_MOVES_SHEET).appendRow([new Date(),dateKey(new Date()),sku,_yarnLabel_(it),'IN',cartons,cones,kg,'Manual IN',String(e.ref||'').trim(),requireUser_(user).name]);
  _SETUP.yarnItems=null; bustMemo_();
  logAudit_(requireUser_(user),'Yarn IN',sku+' · '+cartons+' carton · '+cones+' cones · '+kg+' kg');
  return {ok:true};
}
function yarnWarpingOut_(u,sku,cartons,date,ref){
  setupYarn_(); var items=_yarnItems_(); var it=items[sku]; if(!it) return;
  cartons=round(cartons); if(!(cartons>0)) return;
  var cones=round(cartons*(it.conesPerCarton||0));
  var kg=round(cartons*(it.kgPerCarton||0));
  getSS().getSheetByName(YARN_MOVES_SHEET).appendRow([new Date(),date||dateKey(new Date()),sku,_yarnLabel_(it),'OUT',cartons,cones,kg,'Warping',String(ref||''),u.name]);
  _SETUP.yarnItems=null;
}
/* Raschel-accessible (non-admin): warping entry ke liye yarn list + live stock (carton/cones/kg). */
function getYarnStockWarp(user){
  requireDept_(user,RASCHEL_DEPT); setupYarn_();
  var items=_yarnItems_(); var bal=_yarnBalances_();
  var list=Object.keys(items).map(function(sku){ var it=items[sku]; if(!it.active) return null; var b=bal[sku]||{cartons:0,cones:0,kg:0};
    return {sku:sku,label:_yarnLabel_(it),desc:it.desc,quality:it.quality,brand:it.brand,conesPerCarton:it.conesPerCarton,kgPerCarton:it.kgPerCarton,cartons:round(b.cartons),cones:round(b.cones),kg:round(b.kg)}; }).filter(function(x){return x;});
  list.sort(function(a,b){ return a.label<b.label?-1:1; });
  return {ok:true, yarns:list};
}
